# Copie este arquivo para .env e preencha sua chave:
#   cp .env.example .env

OPENAI_API_KEY=sk-sua-chave-aqui
OPENAI_MODEL=gpt-4o-mini
LIMIAR_CONFIANCA_CRITIC=0.7
LIMIAR_CONFIANCA_DATASHIELD=0.6
MAX_OPTIMUS_RETRIES=1

# HITL: terminal | auto | arquivo | streamlit
HITL_MODE=terminal

# Pesos de ordenacao (Optimus + fila Nexus). Nao alteram R$ exibido.
# PESO_QUESTIONAR_PREMISSA=1.5
# PESO_CAPTURAR_OPORTUNIDADE=1.4
# PESO_INVESTIGAR_DESVIO_PERSISTENTE=1.1

# Resumo executivo estratificado (top N por topico).
# CLI: --top-doi / --top-forward / --top-opps
# TOP_N_DOI=5
# TOP_N_FORWARD=5
# TOP_N_OPORTUNIDADES=5
# Legado (se DOI/FORWARD nao setados): TOP_N_RISCOS replica para ambos
# TOP_N_RISCOS=5

# Filtro de ruido: desvio persistente so entra se impacto OU desvio% passar
# LIMIAR_PERSISTENTE_IMPACTO=100.0
# LIMIAR_PERSISTENTE_DESVIO_PCT=5.0

# Dual Ingress / Power BI (ADR-0025).
# CI: use PBI_FIXTURE_PATH (no network). Live smoke: PBI_ACCESS_TOKEN (Bearer).
PBI_ARTIFACT_ID=8d81650c-ea21-4fc4-8303-d067226f9442
PBI_CATALOG_PATH=catalogs/mondelez_s2r_v1.yaml
# PBI_FIXTURE_PATH=tests/fixtures/pbi_mondelez_catalog_responses.json
# PBI_ACCESS_TOKEN=

# Chat PBI analitico (ADR-0026 / --modo chat).
# CHAT_PBI_TRANSPORT=mcp|rest|mock  (default mcp; mock = CI sem rede)
# PBI_MCP_URL=https://api.fabric.microsoft.com/v1/mcp/powerbi
# CHAT_PBI_TRANSPORT=mock
# Modelo so do chat (ADR-0026). Default no codigo: gpt-5.4
# Batch/Critic continuam em OPENAI_MODEL. Vazio = herda OPENAI_MODEL.
CHAT_OPENAI_MODEL=gpt-5.4
