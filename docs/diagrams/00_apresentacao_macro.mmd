    subgraph S3["RECOMENDAÇÃO"]
        REC[Fila + Resumo executivo<br/>riscos e oportunidades<br/>HITL: humano decide]
    end

    subgraph S4["CONHECIMENTO - futuro"]
        RAG[RAG<br/>consulta à documentação<br/>e auditorias geradas]
    end

    U --> DL --> PIPE --> REC
    REC --> U
    REC -.-> RAG
    U -.-> RAG

    classDef futuro stroke-dasharray: 5 5
